generator client {
  provider = "prisma-client"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id_user    Int        @id @default(autoincrement())
  clerk_id   String     @unique
  username   String     @unique
  email      String     @unique
  avatar_url String
  hairs      Hair[]
  likes      Like[]
  blog_posts BlogPost[]
}

model Hair {
  id_hair     Int        @id @default(autoincrement())
  name        String
  code        String     @db.Text
  code_hash   String     @unique
  image_url   String
  description String?
  created_at  DateTime   @default(now())
  artistId    Int
  artist      User       @relation(fields: [artistId], references: [id_user], onDelete: Cascade)
  likes       Like[]
  categories  Category[] @relation("CategoryToHair")

  @@index([created_at])  
  @@index([artistId])    
}

model Category {
  id_category Int     @id @default(autoincrement())
  description String?
  hairs       Hair[]  @relation("CategoryToHair")
}

model Like {
  id_user Int
  id_hair Int
  hair    Hair @relation(fields: [id_hair], references: [id_hair], onDelete: Cascade)
  user    User @relation(fields: [id_user], references: [id_user], onDelete: Cascade)

  @@id([id_user, id_hair])
  @@index([id_hair])
  @@index([id_user])
}

model BlogCategory {
  id_category Int            @id @default(autoincrement())
  name        String
  slug        String         @unique
  description String?
  parentId    Int?
  parent      BlogCategory?  @relation("BlogCategoryTree", fields: [parentId], references: [id_category], onDelete: Cascade)
  children    BlogCategory[] @relation("BlogCategoryTree")
  posts       BlogPost[]

  @@index([parentId])
}

model BlogPost {
  id_post         Int           @id @default(autoincrement())
  title           String
  slug            String        @unique
  excerpt         String?
  content         String        @db.Text
  cover_image_url String?
  published       Boolean       @default(true)
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt
  authorId        Int
  author          User          @relation(fields: [authorId], references: [id_user], onDelete: Cascade)
  categoryId      Int?
  category        BlogCategory? @relation(fields: [categoryId], references: [id_category], onDelete: SetNull)

  @@index([created_at])
  @@index([categoryId])
  @@index([authorId])
}