---
/**
 * ImageCarousel — premium full-width gallery with smooth slide transitions,
 * keyboard/touch support, and auto-advance. Redesigned from scratch.
 */
import { Image } from "astro:assets";
import img1 from "../assets/carousel/1.png";
import img2 from "../assets/carousel/2.png";
import img3 from "../assets/carousel/3.png";
import img4 from "../assets/carousel/4.png";
import img5 from "../assets/carousel/5.png";

const slides = [img1, img2, img3, img4, img5];
---

<div class="relative w-full select-none" id="gallery-root">

  <!-- Main viewport -->
  <div
    id="gallery-viewport"
    class="relative w-full aspect-video md:aspect-[21/9] rounded-[2rem] md:rounded-[3rem] overflow-hidden border border-white/8 shadow-[0_0_80px_rgba(0,0,0,0.6)] bg-black cursor-grab active:cursor-grabbing"
    aria-label="Gallery"
    role="region"
  >
    <!-- Slides -->
    <div id="gallery-track" class="flex h-full will-change-transform" style="transform: translateX(0%);">
      {slides.map((img, i) => (
        <div class="gallery-slide w-full h-full flex-shrink-0 overflow-hidden">
          <Image
            src={img}
            alt={`DragonMineZ Gallery ${i + 1}`}
            format="webp"
            class="w-full h-full object-cover scale-[1.02] transition-transform duration-700"
            loading={i === 0 ? "eager" : "lazy"}
          />
        </div>
      ))}
    </div>

    <!-- Edge fade for cinematic feel -->
    <div class="absolute inset-y-0 left-0 w-16 bg-gradient-to-r from-black/30 to-transparent pointer-events-none z-10"></div>
    <div class="absolute inset-y-0 right-0 w-16 bg-gradient-to-l from-black/30 to-transparent pointer-events-none z-10"></div>

    <!-- Prev / Next buttons -->
    <button
      id="gallery-prev"
      class="absolute left-4 top-1/2 -translate-y-1/2 z-20 w-12 h-12 rounded-full bg-black/50 backdrop-blur-xl border border-white/15 text-white flex items-center justify-center transition-all duration-200 opacity-0 hover:bg-white hover:text-black hover:scale-110 hover:border-transparent active:scale-95 focus-visible:opacity-100"
      aria-label="Previous"
    >
      <span class="material-symbols-rounded text-xl leading-none">chevron_left</span>
    </button>
    <button
      id="gallery-next"
      class="absolute right-4 top-1/2 -translate-y-1/2 z-20 w-12 h-12 rounded-full bg-black/50 backdrop-blur-xl border border-white/15 text-white flex items-center justify-center transition-all duration-200 opacity-0 hover:bg-white hover:text-black hover:scale-110 hover:border-transparent active:scale-95 focus-visible:opacity-100"
      aria-label="Next"
    >
      <span class="material-symbols-rounded text-xl leading-none">chevron_right</span>
    </button>

    <!-- Counter badge -->
    <div class="absolute top-4 right-4 z-20 px-3 py-1 rounded-full bg-black/50 backdrop-blur-md border border-white/15 text-white/70 text-xs font-bold tracking-widest tabular-nums">
      <span id="gallery-counter">1</span> / {slides.length}
    </div>
  </div>

  <!-- Dot indicators -->
  <div class="flex items-center justify-center gap-2.5 mt-6" id="gallery-dots" role="tablist">
    {slides.map((_, i) => (
      <button
        class={`gallery-dot rounded-full transition-all duration-300 ${i === 0 ? "w-6 h-2 bg-white" : "w-2 h-2 bg-white/30 hover:bg-white/60"}`}
        data-index={i}
        aria-label={`Go to slide ${i + 1}`}
        role="tab"
        aria-selected={i === 0 ? "true" : "false"}
      />
    ))}
  </div>

  <!-- Thumbnail strip -->
  <div class="flex gap-3 mt-4 overflow-x-auto scrollbar-hide pb-1" id="gallery-thumbs">
    {slides.map((img, i) => (
      <button
        class={`gallery-thumb flex-shrink-0 rounded-xl overflow-hidden border-2 transition-all duration-200 ${i === 0 ? "border-white opacity-100" : "border-transparent opacity-50 hover:opacity-80"}`}
        data-index={i}
        aria-label={`Thumbnail ${i + 1}`}
      >
        <Image
          src={img}
          alt={`Thumbnail ${i + 1}`}
          format="webp"
          width={120}
          height={68}
          class="w-[80px] md:w-[120px] h-auto object-cover pointer-events-none"
          loading="lazy"
        />
      </button>
    ))}
  </div>
</div>

<style>
  #gallery-root:hover #gallery-prev,
  #gallery-root:hover #gallery-next {
    opacity: 1;
  }
  #gallery-track {
    transition: transform 600ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  #gallery-track.no-transition {
    transition: none;
  }
</style>

<script>
  function initGallery() {
    const root     = document.getElementById('gallery-root');
    const track    = document.getElementById('gallery-track') as HTMLElement | null;
    const viewport = document.getElementById('gallery-viewport');
    const prevBtn  = document.getElementById('gallery-prev');
    const nextBtn  = document.getElementById('gallery-next');
    const counter  = document.getElementById('gallery-counter');
    const dots     = Array.from(document.querySelectorAll('.gallery-dot')) as HTMLElement[];
    const thumbs   = Array.from(document.querySelectorAll('.gallery-thumb')) as HTMLElement[];
    const slides   = Array.from(document.querySelectorAll('.gallery-slide'));
    const total    = slides.length;

    if (!track || total === 0) return;

    let current = 0;
    let autoTimer: ReturnType<typeof setInterval> | undefined;
    let touchStartX = 0;
    let isDragging = false;

    function updateUI(idx: number) {
      if (counter) counter.textContent = String(idx + 1);

      dots.forEach((d, i) => {
        d.setAttribute('aria-selected', i === idx ? 'true' : 'false');
        if (i === idx) {
          d.classList.add('w-6', 'h-2', 'bg-white');
          d.classList.remove('w-2', 'bg-white/30');
        } else {
          d.classList.remove('w-6', 'h-2', 'bg-white');
          d.classList.add('w-2', 'bg-white/30');
        }
      });

      thumbs.forEach((t, i) => {
        if (i === idx) {
          t.classList.add('border-white', 'opacity-100');
          t.classList.remove('border-transparent', 'opacity-50');
          // Scroll thumb into view
          t.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
        } else {
          t.classList.remove('border-white', 'opacity-100');
          t.classList.add('border-transparent', 'opacity-50');
        }
      });
    }

    function goTo(idx: number, animate = true) {
      if (!animate) track.classList.add('no-transition');
      track.style.transform = `translateX(-${idx * 100}%)`;
      if (!animate) {
        // Force reflow then re-enable
        track.getBoundingClientRect();
        track.classList.remove('no-transition');
      }
      current = idx;
      updateUI(current);
    }

    function next() {
      goTo((current + 1) % total);
    }

    function prev() {
      goTo((current - 1 + total) % total);
    }

    function startAuto() {
      stopAuto();
      autoTimer = setInterval(next, 5500);
    }

    function stopAuto() {
      clearInterval(autoTimer);
    }

    // Button click
    nextBtn?.addEventListener('click', () => { next(); startAuto(); });
    prevBtn?.addEventListener('click', () => { prev(); startAuto(); });

    // Dot click
    dots.forEach((d, i) => {
      d.addEventListener('click', () => { goTo(i); startAuto(); });
    });

    // Thumb click
    thumbs.forEach((t, i) => {
      t.addEventListener('click', () => { goTo(i); startAuto(); });
    });

    // Keyboard
    viewport?.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'ArrowLeft') { prev(); startAuto(); }
      if (e.key === 'ArrowRight') { next(); startAuto(); }
    });

    // Touch / drag
    viewport?.addEventListener('touchstart', (e: TouchEvent) => {
      touchStartX = e.touches[0].clientX;
      stopAuto();
    }, { passive: true });

    viewport?.addEventListener('touchend', (e: TouchEvent) => {
      const dx = e.changedTouches[0].clientX - touchStartX;
      if (Math.abs(dx) > 40) {
        dx < 0 ? next() : prev();
      }
      startAuto();
    });

    // Mouse drag
    let mouseStartX = 0;
    viewport?.addEventListener('mousedown', (e: MouseEvent) => {
      mouseStartX = e.clientX;
      isDragging = true;
      stopAuto();
    });
    document.addEventListener('mouseup', (e: MouseEvent) => {
      if (!isDragging) return;
      isDragging = false;
      const dx = e.clientX - mouseStartX;
      if (Math.abs(dx) > 60) {
        dx < 0 ? next() : prev();
      }
      startAuto();
    });

    // Pause on hover
    root?.addEventListener('mouseenter', stopAuto);
    root?.addEventListener('mouseleave', startAuto);

    // Init
    goTo(0, false);
    startAuto();
  }

  document.addEventListener('astro:page-load', initGallery);
  initGallery();
</script>
