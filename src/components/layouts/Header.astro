---
import { Image } from "astro:assets";
import logo from "../../assets/dmz-title.png";
---

<header 
  id="main-header"
  class="fixed top-0 z-50 w-full transition-all duration-300 ease-in-out border-b border-transparent"
>
  <div class="mx-auto flex h-20 w-full items-center justify-between px-6 md:px-8">
    
    <div class="flex items-center h-full z-[61]">
      <a href="/" class="flex items-center h-full">
        <Image
          src={logo}
          alt="DragonMineZ - Logo"
          class="h-12 md:h-14 w-auto object-contain transition-transform hover:scale-105 active:scale-95"
        />
      </a>
    </div>

    <button 
      id="menu-button"
      class="flex md:hidden items-center justify-center text-[rgb(var(--foreground))] z-[61] p-2 select-none hover:bg-glass rounded-xl transition-colors active:scale-90"
      aria-label="Toggle Menu"
    >
      <span class="material-symbols-rounded text-3xl">menu</span>
    </button>
    
    <nav 
      id="main-nav"
      class="absolute top-full left-0 w-full h-[auto] bg-surface/95 backdrop-blur-xl md:static md:w-auto md:bg-transparent md:backdrop-blur-none flex flex-col md:flex-row items-center p-8 md:p-0 gap-6 md:gap-8 text-xl font-medium text-foreground/80 transition-all duration-300 -translate-y-4 opacity-0 pointer-events-none md:translate-y-0 md:opacity-100 md:pointer-events-auto border-b border-glass-strong md:border-none shadow-dropdown md:shadow-none rounded-b-3xl md:rounded-none z-[60]"
    >
      <a href="#" class="hover:text-foreground transition-colors w-full md:w-auto text-center py-2 md:py-0">Download</a>
      <a href="#" class="hover:text-foreground transition-colors w-full md:w-auto text-center py-2 md:py-0">Discord</a>
      <a href="/hairsalon" class="hover:text-foreground transition-colors w-full md:w-auto text-center py-2 md:py-0">HairSalon</a>
      <a href="https://trello.com/b/xewaqYee/dragonmine-z-trello" class="hover:text-foreground transition-colors w-full md:w-auto text-center py-2 md:py-0">Wiki</a>
    </nav>
  </div>
</header>

<script>
  function initHeader() {
    const header = document.getElementById('main-header');
    const menuButton = document.getElementById('menu-button');
    const menuIcon = menuButton?.querySelector('.material-symbols-rounded');
    const mainNav = document.getElementById('main-nav');
    
    let isMenuOpen = false;
    let isScrolling = false;

    const updateHeaderStyle = () => {
      if (!header) return;

      if (isMenuOpen) {
        header.classList.add('bg-surface', 'border-glass-strong');
        header.classList.remove('backdrop-blur-md', 'border-transparent');
        return;
      }

      if (window.scrollY > 10) {
        header.classList.add('bg-background/70', 'backdrop-blur-md', 'border-glass-strong');
        header.classList.remove('border-transparent', 'bg-surface');
      } else {
        header.classList.remove('bg-background/70', 'bg-surface', 'backdrop-blur-md', 'border-glass-strong');
        header.classList.add('border-transparent');
      }
      
      isScrolling = false;
    };

    const onScroll = () => {
      if (!isScrolling) {
        window.requestAnimationFrame(updateHeaderStyle);
        isScrolling = true;
      }
    };

    const toggleMenu = () => {
      isMenuOpen = !isMenuOpen;
      
      if (mainNav && menuIcon) {
        if (isMenuOpen) {
          mainNav.classList.remove('-translate-y-4', 'opacity-0', 'pointer-events-none');
          mainNav.classList.add('translate-y-0', 'opacity-100', 'pointer-events-auto');
          menuIcon.textContent = 'close';
          document.body.style.overflow = 'hidden';
        } else {
          mainNav.classList.add('-translate-y-4', 'opacity-0', 'pointer-events-none');
          mainNav.classList.remove('translate-y-0', 'opacity-100', 'pointer-events-auto');
          menuIcon.textContent = 'menu';
          document.body.style.overflow = '';
        }
      }
      
      updateHeaderStyle();
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    menuButton?.addEventListener('click', toggleMenu);

    // Initial check
    updateHeaderStyle();
  }

  // Handle Astro page transitions if any
  document.addEventListener('astro:page-load', initHeader);
  // Fallback for initial load
  initHeader();
</script>
