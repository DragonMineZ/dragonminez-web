---
---

<div class="relative w-full group">
    <div id="carousel-container" class="relative aspect-square md:aspect-[21/9] rounded-[2rem] overflow-hidden border border-glass shadow-hero bg-black/20">
        <div id="carousel-track" class="flex h-full will-change-transform">

            <!-- Clon del último slide -->
            <div class="carousel-slide w-full h-full flex-shrink-0">
                <div class="overflow-hidden w-full h-full">
                    <img src="/carousel/5.png" alt="Clone Last" class="w-full h-full object-cover transition-transform duration-500 hover:scale-110" />
                </div>
            </div>

            <!-- Slide 1 -->
            <div class="carousel-slide w-full h-full flex-shrink-0">
                <div class="overflow-hidden w-full h-full">
                    <img src="/carousel/1.png" alt="DragonMineZ Gallery 1" class="w-full h-full object-cover transition-transform duration-500 hover:scale-110" />
                </div>
            </div>

            <!-- Slide 2 -->
            <div class="carousel-slide w-full h-full flex-shrink-0">
                <div class="overflow-hidden w-full h-full">
                    <img src="/carousel/2.png" alt="DragonMineZ Gallery 2" class="w-full h-full object-cover transition-transform duration-500 hover:scale-110" />
                </div>
            </div>

            <!-- Slide 3 -->
            <div class="carousel-slide w-full h-full flex-shrink-0">
                <div class="overflow-hidden w-full h-full">
                    <img src="/carousel/3.png" alt="DragonMineZ Gallery 3" class="w-full h-full object-cover transition-transform duration-500 hover:scale-110" />
                </div>
            </div>

            <!-- Slide 4 -->
            <div class="carousel-slide w-full h-full flex-shrink-0">
                <div class="overflow-hidden w-full h-full">
                    <img src="/carousel/4.png" alt="DragonMineZ Gallery 4" class="w-full h-full object-cover transition-transform duration-500 hover:scale-110" />
                </div>
            </div>

            <!-- Slide 5 -->
            <div class="carousel-slide w-full h-full flex-shrink-0">
                <div class="overflow-hidden w-full h-full">
                    <img src="/carousel/5.png" alt="DragonMineZ Gallery 5" class="w-full h-full object-cover transition-transform duration-500 hover:scale-110" />
                </div>
            </div>

            <!-- Clon del primer slide -->
            <div class="carousel-slide w-full h-full flex-shrink-0">
                <div class="overflow-hidden w-full h-full">
                    <img src="/carousel/1.png" alt="Clone First" class="w-full h-full object-cover transition-transform duration-500 hover:scale-110" />
                </div>
            </div>

        </div>
    </div>

    <!-- Navigation Arrows -->
    <button id="carousel-prev" class="absolute left-4 top-1/2 -translate-y-1/2 w-12 h-12 bg-black/50 backdrop-blur-xl border border-glass-strong rounded-full flex items-center justify-center text-white opacity-0 group-hover:opacity-100 transition-all duration-300 hover:bg-white hover:text-black hover:scale-110 z-10">
        <i class="fa-solid fa-chevron-left"></i>
    </button>
    <button id="carousel-next" class="absolute right-4 top-1/2 -translate-y-1/2 w-12 h-12 bg-black/50 backdrop-blur-xl border border-glass-strong rounded-full flex items-center justify-center text-white opacity-0 group-hover:opacity-100 transition-all duration-300 hover:bg-white hover:text-black hover:scale-110 z-10">
        <i class="fa-solid fa-chevron-right"></i>
    </button>

    <!-- Indicators -->
    <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-2 z-10">
        <button class="carousel-indicator w-3 h-3 rounded-full bg-white transition-all duration-300" data-index="0"></button>
        <button class="carousel-indicator w-3 h-3 rounded-full bg-white/40 transition-all duration-300" data-index="1"></button>
        <button class="carousel-indicator w-3 h-3 rounded-full bg-white/40 transition-all duration-300" data-index="2"></button>
        <button class="carousel-indicator w-3 h-3 rounded-full bg-white/40 transition-all duration-300" data-index="3"></button>
        <button class="carousel-indicator w-3 h-3 rounded-full bg-white/40 transition-all duration-300" data-index="4"></button>
    </div>
</div>

<script>
    const track = document.getElementById('carousel-track') as HTMLElement | null;
    const prevBtn = document.getElementById('carousel-prev');
    const nextBtn = document.getElementById('carousel-next');
    const indicators = document.querySelectorAll('.carousel-indicator');

    let currentIndex = 1;
    const realSlides = 5;
    let isTransitioning = false;
    let autoplayInterval: ReturnType<typeof setInterval> | undefined;

    function updateIndicators(index: number) {
        const displayIndex = (index - 1 + realSlides) % realSlides;
        indicators.forEach((indicator, i) => {
            indicator.classList.toggle('bg-white', i === displayIndex);
            indicator.classList.toggle('bg-white/40', i !== displayIndex);
        });
    }

    function goTo(index: number, animate = true) {
        if (!track) return;
        track.style.transition = animate ? 'transform 800ms ease-in-out' : 'none';
        track.style.transform = `translateX(-${index * 100}%)`;
        currentIndex = index;
        if (animate) updateIndicators(index);
    }

    function startAutoplay() {
        clearInterval(autoplayInterval);
        autoplayInterval = setInterval(nextSlide, 6000);
    }

    function stopAutoplay() {
        clearInterval(autoplayInterval);
    }

    function nextSlide() {
        if (isTransitioning) return;
        isTransitioning = true;
        stopAutoplay();

        goTo(currentIndex + 1);

        setTimeout(() => {
            if (currentIndex === realSlides + 1) {
                goTo(1, false);
                updateIndicators(1);
            }
            isTransitioning = false;
            startAutoplay();
        }, 800);
    }

    function prevSlide() {
        if (isTransitioning) return;
        isTransitioning = true;
        stopAutoplay();

        goTo(currentIndex - 1);

        setTimeout(() => {
            if (currentIndex === 0) {
                goTo(realSlides, false);
                updateIndicators(realSlides);
            }
            isTransitioning = false;
            startAutoplay();
        }, 800);
    }

    goTo(1, false);

    nextBtn?.addEventListener('click', () => nextSlide());
    prevBtn?.addEventListener('click', () => prevSlide());

    indicators.forEach((indicator) => {
        indicator.addEventListener('click', () => {
            if (isTransitioning) return;
            const index = parseInt(indicator.getAttribute('data-index') || '0');
            stopAutoplay();
            goTo(index + 1);
            setTimeout(() => startAutoplay(), 800);
        });
    });

    const container = document.getElementById('carousel-container');
    container?.addEventListener('mouseenter', stopAutoplay);
    container?.addEventListener('mouseleave', startAutoplay);

    startAutoplay();
</script>