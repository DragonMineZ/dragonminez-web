---
import Header from "../components/layouts/Header.astro";
import Footer from "../components/layouts/Footer.astro";
import FloatingMenu from "../components/ui/FloatingMenu";
import { AppProviders } from "../providers/AppProviders";

import '@fontsource-variable/onest';
import "../styles/global.css";
---

<!doctype html>
<html class="dark" lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        return 'dark';
      })();
    
      if (theme === 'light') {
        document.documentElement.classList.remove('dark');
      } else {
        document.documentElement.classList.add('dark');
      }
    </script>

    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" integrity="sha512-Evv84Mr4kqVGRNSgIGL/F/aIDqQb7xQ2vcrdIwxfjThSH8CSR7PBEakCr51Ck+w+/U6swU2Im1vVX0SVk9ABhg==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <title>DragonMineZ - El mejor mod de Dragon Ball Z para Minecraft</title>
  </head>
  <body class="bg-background text-foreground selection:bg-foreground/10">
    <AppProviders client:load>
      <Header />
      <slot />
      <Footer />
      <FloatingMenu client:load />
    </AppProviders>

    <script>
      import { i18nStore } from "../i18n/store";

      function updateI18nElements() {
        const { translations, isLoaded } = i18nStore.getState();
        if (!isLoaded || !translations) return;

        const elements = document.querySelectorAll('[data-i18n]');
        elements.forEach((el) => {
          const path = el.getAttribute('data-i18n');
          if (!path) return;

          const keys = path.split('.');
          let value: any = translations;
          
          for (const key of keys) {
            if (value && typeof value === 'object' && key in value) {
              value = value[key];
            } else {
              value = path;
              break;
            }
          }

          if (typeof value === 'string') {
            // Support for placeholder attribute if requested
            if (el.hasAttribute('data-i18n-placeholder')) {
              el.setAttribute('placeholder', value);
            } else {
              el.textContent = value;
            }
          }
        });
      }

      // Initial update
      updateI18nElements();

      // Subscribe to store changes
      i18nStore.subscribe(updateI18nElements);

      // Handle Astro page transitions (View Transitions)
      document.addEventListener('astro:page-load', () => {
        updateI18nElements();
        i18nStore.subscribe(updateI18nElements);
      });
    </script>
  </body>
</html>
