---
import Layout from "../../../layouts/Layout.astro";
import PostEditor from "../../../components/features/blog/PostEditor.tsx";
import { findPostWithAuthor } from "../../../repositories/blog.repository";
import { getUserPermissions } from "../../../services/permission.service";

// Middleware already requires sign-in for this route.
const { userId } = Astro.locals.auth();

const postId = Number.parseInt(Astro.params.id ?? "", 10);
if (!Number.isInteger(postId) || postId <= 0) return Astro.redirect("/404");

const post = await findPostWithAuthor(postId);
if (!post) return Astro.redirect("/404");

// Only the author can edit their post (and they must still hold the role).
const isOwner = post.author.clerk_id === userId;
const permissions = await getUserPermissions(Astro, userId);
if (!isOwner || !permissions.canPostBlog) return Astro.redirect("/blog");

const initialData = {
    id_post: post.id_post,
    title: post.title,
    excerpt: post.excerpt,
    content: post.content,
    cover_image_url: post.cover_image_url,
    categoryId: post.categoryId,
    published: post.published,
};
---

<Layout title="Editar Publicación | DragonMineZ" i18nTitle="blog.form.editTitle" noindex>
    <section class="container-base py-24 md:py-32">
        <div class="max-w-3xl mx-auto">
            <div class="mb-10">
                <h1
                    class="text-3xl sm:text-4xl font-black italic uppercase tracking-tighter text-foreground"
                    data-i18n="blog.form.editTitle"
                >
                    Editar Publicación
                </h1>
                <p class="text-muted mt-2" data-i18n="blog.form.editDesc">
                    Actualiza el contenido de tu publicación
                </p>
            </div>
            <PostEditor client:only="react" initialData={initialData} />
        </div>
    </section>
</Layout>
