---
import Layout from "../../layouts/Layout.astro";
import PostEditor from "../../components/features/blog/PostEditor.tsx";
import { getUserPermissions } from "../../services/permission.service";

// Middleware already requires sign-in for this route.
const { userId } = Astro.locals.auth();
const permissions = await getUserPermissions(Astro, userId);
const canPost = permissions.canPostBlog;
---

<Layout title="Nueva Publicación | DragonMineZ" i18nTitle="blog.form.createTitle" noindex>
    <section class="container-base py-24 md:py-32">
        <div class="max-w-3xl mx-auto">
            {
                canPost ? (
                    <>
                        <div class="mb-10">
                            <h1
                                class="text-3xl sm:text-4xl font-black italic uppercase tracking-tighter text-foreground"
                                data-i18n="blog.form.createTitle"
                            >
                                Nueva Publicación
                            </h1>
                            <p class="text-muted mt-2" data-i18n="blog.form.createDesc">
                                Comparte novedades, guías o historias con la comunidad
                            </p>
                        </div>
                        <PostEditor client:only="react" />
                    </>
                ) : (
                    <div class="flex flex-col items-center text-center gap-5 py-20 px-8 bg-glass border border-glass rounded-[2.5rem]">
                        <span class="material-symbols-outlined text-6xl text-muted">verified_user</span>
                        <h1 class="text-2xl font-black text-foreground" data-i18n="blog.authorRequired">
                            Rol de Autor Requerido
                        </h1>
                        <p class="text-muted max-w-md" data-i18n="blog.authorRequiredDesc">
                            Necesitas el rol de Autor DMZ en nuestro Discord para publicar en el blog.
                        </p>
                        <div class="flex gap-3 mt-2">
                            <a
                                href="https://discord.com/servers/dragonmine-z-1216429657273012415"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="inline-flex items-center gap-2 px-6 py-3 bg-foreground text-background rounded-full font-bold text-sm hover:scale-105 active:scale-95 transition-transform"
                            >
                                <i class="fa-brands fa-discord"></i>
                                Discord
                            </a>
                            <a
                                href="/blog"
                                class="inline-flex items-center gap-2 px-6 py-3 bg-glass border border-glass text-foreground rounded-full font-bold text-sm hover:bg-glass-strong transition-colors"
                            >
                                <span data-i18n="blog.backToBlog">Volver al Blog</span>
                            </a>
                        </div>
                    </div>
                )
            }
        </div>
    </section>
</Layout>
