---
import Layout from "../layouts/Layout.astro";
import HairList from "../components/HairList";
import {
  SignedIn,
  SignedOut,
  UserButton,
  SignInButton
} from "@clerk/astro/components";
---

<Layout>
  <section class="max-w-7xl mx-auto px-6 py-16">
    
      <!-- Auth Section -->
      <SignedOut>
        <div class="flex items-center gap-4 text-sm text-gray-500">
          <p>Para publicar tu cabello, inicia sesión</p>
          <SignInButton
            mode="modal"
            class="px-4 py-2 bg-black text-white rounded-lg hover:opacity-90 transition"
          >
            Iniciar Sesión
          </SignInButton>
        </div>
      </SignedOut>

      <SignedIn client:load>
        <UserButton />
      </SignedIn>
    </div>

    <!-- Hair List -->
    <HairList client:load />

  </section>
</Layout>