---
import Layout from "../layouts/Layout.astro";
import HairList from "../components/HairList";
import {
  SignedIn,
  SignedOut,
  UserButton,
  SignInButton
} from "@clerk/astro/components";
---

<Layout>
  <section class="max-w-7xl mx-auto px-6 pt-28 pb-16">
    
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-12">
      <div>
        <h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-5xl">
          HairSalon
        </h1>
        <SignedOut>
          <div class="mt-2 flex items-center gap-1.5">
            <p class="text-gray-400">Si quieres publicar un cabello primero deberás</p>
            <SignInButton mode="modal">
                iniciar sesión.
            </SignInButton>
          </div>
        </SignedOut>
      </div>

      <SignedIn>
        <div class="flex items-center gap-6">
          <a
            href="/createhair"
            class="group relative inline-flex items-center gap-2 px-6 py-3 font-bold text-white transition-all bg-orange-600 rounded-xl hover:bg-orange-500 hover:shadow-[0_0_20px_rgba(234,88,12,0.4)] active:scale-95"
          >
            <span class="material-symbols-outlined transition-transform group-hover:rotate-90">
              add
            </span>
            Crear Cabello
          </a>
          <UserButton afterSignOutUrl="/hairsalon" />
        </div>
      </SignedIn>
    </div>

    <!-- Hair List (React Island) -->
    <HairList client:load />

  </section>
</Layout>