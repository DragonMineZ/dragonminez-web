---
import Layout from "../layouts/Layout.astro";
import HairList from "../components/features/hairs/HairList.tsx";
import CreateHairTrigger from "../components/features/hairs/CreateHairTrigger.tsx";
import {
  SignedIn,
  SignedOut,
  UserButton,
  SignInButton
} from "@clerk/astro/components";
import { createClerkClient } from "@clerk/astro/server";

const { userId } = Astro.locals.auth();
let username = "";

if (userId) {
  const clerk = createClerkClient({ secretKey: import.meta.env.CLERK_SECRET_KEY });
  const user = await clerk.users.getUser(userId);
  username = user.username || user.firstName || ""; // Let i18n handle fallback if empty
}
---

<Layout title="HairSalon | DragonMineZ">
  <section class="container-base py-24 md:py-32">
    
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-12">
      <div>
        <h1 class="text-4xl font-extrabold tracking-tight text-foreground sm:text-5xl" data-i18n="hairSalon.title">
          HairSalon
        </h1>
        <SignedOut>
          <div class="mt-2 flex items-center gap-1.5">
            <p class="text-muted" data-i18n="hairSalon.authRequired">Si quieres publicar un cabello primero deberás</p>
            <SignInButton mode="modal" class="text-foreground hover:underline cursor-pointer">
              <span data-i18n="hairSalon.loginToPublish">iniciar sesión.</span>
            </SignInButton>
          </div>
        </SignedOut>
        <SignedIn>
          <p class="text-muted mt-2">
            <span data-i18n="common.welcome">¡Bienvenido</span> <span class="text-foreground font-semibold">{username || <span data-i18n="hairSalon.usernameFallback">Guerrer@</span>}</span>!, <span data-i18n="hairSalon.publishCreations">puedes empezar a publicar tus creaciones</span>
          </p>
        </SignedIn>
      </div>

      <SignedIn>
        <div class="flex items-center gap-3 bg-surface border border-glass rounded-full pl-1.5 pr-4 py-1.5 shadow-glass">
          <UserButton afterSignOutUrl="/hairsalon" />
          <span class="text-foreground font-bold tracking-tight">{username}</span>
        </div>
      </SignedIn>
    </div>

    <!-- Hair List (React Island) -->
    <HairList client:load />

  </section>
</Layout>