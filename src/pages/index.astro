---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import heroImage from "../assets/dmz-hero.png";
import characters from "../assets/dmz-characters.png";
import aurora from "../assets/updates/dmz-aurora.png";
---

<Layout>
  <main>
    <!-- Hero Section -->
    <section class="relative min-h-screen flex items-center px-8 pt-32 pb-40 overflow-hidden bg-black">
      <!-- Full-bleed background image - Raw with top gradient for header visibility -->
      <div class="absolute inset-0 z-0">
        <Image 
          src={heroImage} 
          alt="DragonMineZ Hero Background" 
          class="w-full h-full object-cover"
          loading="eager"
        />
        <!-- Top shadow for header readability (High intensity) -->
        <div class="absolute inset-0 bg-gradient-to-b from-black/70 via-black/40 to-transparent h-1/3"></div>
        <!-- Bottom fade using the theme's background color for perfect integration -->
        <div class="absolute inset-0 bg-gradient-to-t from-[rgb(var(--background))] via-[rgb(var(--background))]/50 to-transparent h-1/3 mt-auto"></div>
      </div>

      <div class="container mx-auto max-w-7xl z-10">
        <div class="flex flex-col gap-8 text-left max-w-3xl">
          <h1 class="text-6xl md:text-8xl lg:text-[7rem] font-black text-white italic leading-[0.9] tracking-tighter drop-shadow-[0_10px_30px_rgba(0,0,0,0.8)]">
            ¡Tu aventura <br/>empieza aquí!
          </h1>
          <p class="text-xl md:text-3xl text-white/90 font-medium leading-relaxed max-w-2xl drop-shadow-[0_4px_10px_rgba(0,0,0,0.8)]">
            Vive la experiencia de Dragon Ball y recorre la historia junto a Goku.
          </p>
        </div>
      </div>
    </section>

    <!-- Update & Trailer Sections (Default Background) -->
    <div class="w-full pt-24 pb-16 space-y-20 flex flex-col items-center">
      
      <!-- Aurora Update Block -->
      <div class="w-full max-w-4xl px-8">
        <div class="relative group cursor-pointer overflow-hidden rounded-[2.5rem] border border-white/5 shadow-[0_0_50px_rgba(0,0,0,0.5)] transition-all duration-500 hover:scale-[1.01] hover:border-white/10 active:scale-100">
          <Image 
            src={aurora} 
            alt="Aurora Update" 
            class="w-full h-auto object-cover transition-transform duration-700 group-hover:scale-105"
          />
          <div class="absolute bottom-6 right-8">
             <span class="inline-flex items-center gap-2 px-5 py-2.5 bg-black/40 backdrop-blur-xl border border-white/10 rounded-full text-sm font-bold text-white shadow-2xl transition-all group-hover:bg-white group-hover:text-black group-hover:scale-105">
               View All New Features »
             </span>
          </div>
        </div>
      </div>

      <!-- Video Trailer Section -->
      <div class="w-full max-w-4xl px-8 flex flex-col items-center gap-8">
        <div class="flex flex-col gap-3 text-center">
          <h3 class="text-3xl md:text-4xl font-black text-white tracking-tight">
            Mira el trailer pe batedia sedia
          </h3>
          <p class="text-[rgb(var(--foreground))]/60 max-w-lg mx-auto leading-relaxed">
            Causa yapeame, esta pagina no se mantiene sola +51974666807
          </p>
        </div>
        
        <div class="relative w-full aspect-video rounded-[2rem] overflow-hidden border border-white/5 shadow-[0_0_80px_rgba(0,0,0,0.6)] bg-black/20 group max-w-3xl">
          <iframe 
            class="absolute inset-0 w-full h-full"
            src="https://www.youtube.com/embed/Y7HnXFOK0w4" 
            title="DragonMineZ - Aurora Update Trailer" 
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
            referrerpolicy="strict-origin-when-cross-origin" 
            allowfullscreen
          ></iframe>
        </div>
      </div>
    </div>

    <!-- Characters Section (Dark Background #1C1B22) -->
    <div class="w-full bg-[#1C1B22] py-32">
      <div class="w-full max-w-7xl mx-auto px-8 grid grid-cols-1 md:grid-cols-2 items-center gap-16">
        <div class="flex flex-col gap-8 text-left order-2 md:order-1">
          <h2 class="text-6xl md:text-7xl font-black text-white leading-tight italic tracking-tighter">
            Lorem ipsum <br/>dolor for
          </h2>
          <div class="flex flex-col gap-6">
            <p class="text-xl text-[rgb(var(--foreground))]/80 leading-relaxed max-w-xl">
              Lorem ipsum dolor sit amet, consectetur adipiscing elit. Aliquam at porttitor sem. 
            </p>
            <p class="text-xl text-[rgb(var(--foreground))]/80 leading-relaxed max-w-xl">
              Quisque ut interdum augue, non efficitur neque. Mauris tristique varius eros ut convallis.
            </p>
            <p class="text-xl text-[rgb(var(--foreground))]/80 leading-relaxed pt-2 max-w-xl">
              Etiam sodales neque non ipsum sagittis lacinia non ut lorem.<br/>
              Ut efficitur quis tortor sed.
            </p>
          </div>
        </div>

        <div class="flex justify-center md:justify-end order-1 md:order-2">
          <div class="relative group">
            <Image 
              src={characters} 
              alt="DragonMineZ Characters" 
              class="w-full max-w-[720px] h-auto object-contain drop-shadow-[0_0_100px_rgba(0,0,0,0.6)] transition-all duration-700 ease-out group-hover:scale-105 cursor-pointer md:translate-x-8"
            />
          </div>
        </div>
      </div>
    </div>

    <!-- Discord CTA Section (Default Background) -->
    <div class="w-full py-20 flex flex-col items-center justify-center text-center px-8">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
        Have Questions or Feedback?
      </h2>
      <a 
        href="https://discord.com" 
        target="_blank" 
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2.5 px-6 py-3 bg-[#EBEBEB] text-[#1A1A1A] rounded-full font-bold transition-all hover:scale-105 active:scale-95 shadow-xl hover:shadow-[0_0_30px_rgba(255,255,255,0.1)]"
      >
        <i class="fa-brands fa-discord text-xl"></i>
        Join our Discord server!
      </a>
    </div>
  </main>
</Layout>