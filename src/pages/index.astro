---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import heroImage from "../assets/dmz-hero.png";
import characters from "../assets/dmz-characters.png";
import aurora from "../assets/updates/dmz-aurora.png";
import ImageCarousel from "../components/ui/ImageCarousel.astro";
import { Button } from "../components/ui/Button";
---

<Layout>
  <main>

    <!-- 1. Hero Section -->
    <section class="relative min-h-screen flex items-end overflow-hidden bg-black">
      <div class="absolute inset-0 z-0">
        <Image 
          src={heroImage} 
          alt="DragonMineZ Hero Background" 
          class="w-full h-full object-cover"
          loading="eager"
        />
        <div class="absolute inset-x-0 top-0 h-1/3 bg-gradient-to-b from-black/80 via-black/40 to-transparent"></div>
        <div class="absolute inset-x-0 bottom-0 h-2/3 bg-gradient-to-t from-section via-section/60 to-transparent"></div>
      </div>

      <div class="container-base relative z-10 pb-24 md:pb-32 pt-48">
        <div class="flex flex-col gap-6 max-w-3xl">
          <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-[7rem] font-black text-white italic leading-[0.9] tracking-tighter drop-shadow-hero">
            ¡Tu aventura <br/>empieza aquí!
          </h1>
          <p class="text-lg sm:text-xl md:text-2xl text-white/80 font-medium leading-relaxed max-w-2xl">
            Vive la experiencia de Dragon Ball y recorre la historia junto a Goku.
          </p>
          <div class="flex flex-wrap items-center gap-4 pt-4">
            <a href="/hairsalon">
              <Button variant="primary" size="lg" className="gap-3">
                <span class="material-symbols-rounded text-xl">download</span>
                Descargar Mod
              </Button>
            </a>
          </div>
        </div>
      </div>

      <div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2 animate-bounce opacity-60">
        <span class="material-symbols-rounded text-white text-2xl">keyboard_arrow_down</span>
      </div>
    </section>

    <!-- 2. Latest Update Showcase (Aurora) -->
    <section class="py-24 md:py-32 bg-section">
      <div class="container-base">
        <div class="flex flex-col lg:flex-row items-center gap-12 md:gap-20">
          <div class="flex-1 space-y-8">
            <div class="space-y-4">
              <span class="text-foreground font-bold tracking-widest uppercase text-sm">Última Versión</span>
              <h2 class="text-4xl md:text-5xl lg:text-6xl font-black text-white leading-tight tracking-tighter italic uppercase">
                AURORA <br/>UPDATE
              </h2>
            </div>
            <p class="text-xl text-foreground/70 leading-relaxed max-w-xl">
              Nuestra mayor actualización hasta la fecha. Hemos rediseñado por completo el sistema de renderizado para ofrecer efectos visuales impresionantes, nuevas transformaciones y una estabilidad sin precedentes.
            </p>
            <div class="flex items-center gap-6">
              <Button variant="primary" size="lg" className="gap-3">
                <span class="material-symbols-rounded text-xl">article</span>
                Ver Notas del Parche
              </Button>
            </div>
          </div>
          
          <div class="flex-1 w-full">
            <div class="relative group cursor-pointer overflow-hidden rounded-[2.5rem] border border-glass shadow-card-hover transition-all duration-500 hover:scale-[1.01] hover:border-glass-strong active:scale-100">
              <Image 
                src={aurora} 
                alt="Aurora Update Preview" 
                class="w-full h-auto object-cover transition-transform duration-700 group-hover:scale-105"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="section-divider"></div>

    <!-- 3. HairSalon Spotlight -->
    <section class="py-24 md:py-32 overflow-hidden bg-section">
      <div class="container-base grid grid-cols-1 md:grid-cols-2 items-center gap-12">
        
        <div class="relative flex justify-center md:justify-start">
          <Image 
            src={characters} 
            alt="DragonMineZ Characters Showcase" 
            class="w-full max-w-[520px] md:max-w-none md:w-[110%] md:-ml-8 h-auto object-contain drop-shadow-portrait transition-all duration-700 ease-out hover:scale-105"
          />
        </div>

        <div class="flex flex-col gap-8 text-left">
          <div class="space-y-4">
            <span class="text-foreground font-bold tracking-widest uppercase text-sm">Tu Guerrero, Tu Estilo</span>
            <h2 class="text-4xl md:text-5xl lg:text-6xl font-black text-white leading-[1.1] italic tracking-tighter uppercase">
              DISEÑA TU <br/>PROPIA IDENTIDAD
            </h2>
          </div>
          <div class="flex flex-col gap-5">
            <p class="text-lg text-foreground/80 leading-relaxed">
              En DragonMineZ, no eres solo un jugador más. Te ofrecemos las herramientas para que tu guerrero sea verdaderamente único.
            </p>
            <p class="text-lg text-foreground/80 leading-relaxed">
              A través de nuestro HairSalon, puedes explorar miles de modelos creados por la comunidad o subir los tuyos propios usando nuestro visor 3D en tiempo real.
            </p>
          </div>
          <div class="pt-2 flex flex-wrap gap-4">
            <a href="/hairsalon">
              <Button variant="primary" size="lg" className="gap-3">
                <span class="material-symbols-rounded text-xl">styler</span>
                Explorar el Salón
              </Button>
            </a>
          </div>
        </div>

      </div>
    </section>

    <div class="section-divider"></div>

    <!-- 4. Video Trailer Section -->
    <section class="py-24 md:py-32 bg-section">
      <div class="container-base flex flex-col items-center gap-16">
        <div class="flex flex-col gap-4 text-center">
          <h3 class="text-3xl md:text-5xl font-black text-white italic tracking-tight uppercase">
            Acción en Estado Puro
          </h3>
          <p class="text-foreground/60 max-w-xl mx-auto leading-relaxed text-lg">
            Echa un vistazo a la fluidez del combate y los efectos visuales que hacen de DragonMineZ una experiencia inigualable.
          </p>
        </div>
        
        <div class="relative w-full aspect-video rounded-[3rem] overflow-hidden border border-glass shadow-hero bg-black/20 group">
          <div class="absolute inset-0 transition-transform duration-700 group-hover:scale-105">
            <iframe 
              class="absolute inset-0 w-full h-full"
              src="https://www.youtube.com/embed/Y7HnXFOK0w4" 
              title="DragonMineZ - Aurora Update Trailer" 
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
              referrerpolicy="strict-origin-when-cross-origin" 
              allowfullscreen
            ></iframe>
          </div>
        </div>
      </div>
    </section>

    <div class="section-divider"></div>

    <!-- 5. Gallery Section -->
    <section class="py-24 md:py-32 bg-section">
      <div class="container-base flex flex-col items-center gap-16">
        <div class="flex flex-col gap-4 text-center">
          <h3 class="text-3xl md:text-5xl font-black text-white italic tracking-tight uppercase">
            Galería del Mundo
          </h3>
          <p class="text-foreground/60 max-w-lg mx-auto leading-relaxed text-lg">
            Capturas directas desde el corazón de la aventura.
          </p>
        </div>
        <ImageCarousel />
      </div>
    </section>

    <!-- 6. Community Discord Section -->
    <section class="py-24 md:py-32">
      <div class="container-base">
        <div class="relative overflow-hidden rounded-[4rem] bg-[#5865F2] p-12 md:p-24 text-center flex flex-col items-center justify-center gap-10 shadow-alert">
          <div class="absolute inset-0 z-0 opacity-10 flex items-center justify-center">
            <i class="fa-brands fa-discord text-[45rem] rotate-12"></i>
          </div>
          <div class="relative z-10 space-y-8">
            <div class="space-y-4">
              <h2 class="text-4xl md:text-7xl font-black text-white italic tracking-tighter uppercase leading-[0.9]">
                ÚNETE A LA PATRULLA <br/>DEL TIEMPO
              </h2>
              <p class="text-xl md:text-2xl text-white/90 max-w-2xl mx-auto font-medium leading-relaxed">
                Conéctate con miles de jugadores, encuentra grupos para incursiones y obtén soporte directo de los desarrolladores.
              </p>
            </div>
            <div class="flex justify-center pt-4">
              <a 
                href="https://discord.com" 
                target="_blank" 
                rel="noopener noreferrer"
                class="inline-flex items-center gap-4 px-12 py-6 bg-white text-[#5865F2] rounded-full font-black text-xl transition-all hover:scale-110 active:scale-95 shadow-hero hover:shadow-glow-strong"
              >
                <i class="fa-brands fa-discord text-3xl"></i>
                ENTRAR AL DISCORD
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>
</Layout>