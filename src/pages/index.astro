---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import heroImage from "../assets/dmz-hero.png";
import characters from "../assets/dmz-characters.png";
import endofzImage from "../assets/updates/endofz/dmz-endofz.png";
import voteBackground from "../assets/dmz-vote.png";
import endofzLogo from "../assets/updates/endofz/dmz-endofz-logo.png";
import PatchNotesModal from "../components/features/updates/PatchNotesModal";
import ImageCarousel from "../components/ImageCarousel.astro";
import { Button } from "../components/ui/Button";
import { DownloadDropdown } from "../components/ui/DownloadDropdown";
import curseforgeIcon from "../assets/icons/social/curseforge.svg?raw";
import modrinthIcon from "../assets/icons/social/modrinth.svg?raw";
---

<Layout>
  <main>

    <!-- ── Hero -->
    <section class="relative min-h-screen flex items-end bg-background">
      <div class="absolute inset-0 z-0">

        <Image 
          src={heroImage} 
          alt="DragonMineZ Hero Background" 
          class="w-full h-full object-cover"
          loading="eager"
          fetchpriority="high"
        />
        <div class="absolute inset-x-0 top-0 h-1/4 bg-gradient-to-b from-black/50 via-black/20 to-transparent"></div>
        <div class="absolute inset-x-0 bottom-0 h-[20rem] bg-gradient-to-t from-section via-section/40 to-transparent"></div>
      </div>

      <div class="container-base relative z-10 pb-24 md:pb-32 pt-48">
        <div class="flex flex-col gap-6 max-w-3xl">
          <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-[7rem] font-black text-white italic leading-[0.9] tracking-tighter drop-shadow-hero" data-i18n="home.hero.title">
            ¡Tu aventura <br/>empieza aquí!
          </h1>
          <p class="text-lg sm:text-xl md:text-2xl text-white/80 font-medium leading-relaxed max-w-2xl" data-i18n="home.hero.subtitle">
            Vive la experiencia de Dragon Ball y recorre la historia junto a Goku.
          </p>
          <div class="flex flex-wrap items-center gap-4 pt-4">
            <DownloadDropdown 
              client:idle 
              variant="primary" 
              size="lg" 
              curseforgeIcon={curseforgeIcon} 
              modrinthIcon={modrinthIcon}
            />
          </div>
        </div>
      </div>


      <div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2 animate-bounce opacity-60">
        <span class="material-symbols-rounded text-foreground text-2xl">keyboard_arrow_down</span>
      </div>
    </section>

    <!-- ── Aurora Update -->
    <section class="py-24 md:py-32 bg-section">

      <div class="container-base">
        <div class="flex flex-col lg:flex-row items-center gap-12 md:gap-20">
          <div class="flex-1 space-y-8">
            <div class="space-y-6">
              <div class="space-y-3 animate-slide-in-soft">
                <span class="text-foreground/60 font-bold tracking-widest uppercase text-xs" data-i18n="home.endofz.tag">Última Versión</span>
                <h2 class="relative inline-block leading-none">
                  <span class="sr-only" data-i18n="home.endofz.title">END OF Z UPDATE</span>
                  <Image 
                    src={endofzLogo} 
                    alt="End of Z Update Logo" 
                    class="h-24 md:h-32 w-auto object-contain drop-shadow-hero transition-transform duration-500 hover:scale-[1.02] origin-left -ml-3 md:-ml-4"
                  />
                </h2>
              </div>
            </div>
            <p class="text-xl text-foreground/70 leading-relaxed max-w-xl" data-i18n="home.endofz.description">
              La batalla definitiva ha comenzado. Disfruta de un sistema de combate cuerpo a cuerpo renovado, una campaña de misiones completa por la saga Z, choques de Ki en tiempo real y clases RPG con pasivas únicas.
            </p>
            <div class="flex items-center gap-6">
              <PatchNotesModal client:load />
            </div>
          </div>
          
          <div class="flex-1 w-full">
            <div class="relative group cursor-pointer overflow-hidden rounded-[2.5rem] border border-glass shadow-card-hover transition-all duration-500 hover:scale-[1.01] hover:border-glass-strong active:scale-100">
              <Image 
                src={endofzImage} 
                alt="End of Z Update Preview" 
                class="w-full h-auto object-cover transition-transform duration-700 group-hover:scale-105"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="section-divider"></div>

    <!-- ── Race Vote CTA -->
    <section class="relative py-24 md:py-32 overflow-hidden">
      <div class="absolute inset-0 z-0 bg-background">
        <Image 
          src={voteBackground} 
          alt="Vote Background" 
          class="w-full h-full object-cover opacity-25 pointer-events-none mix-blend-luminosity grayscale"
        />
        <div class="absolute inset-0 bg-gradient-to-b from-section via-background/50 to-section"></div>
      </div>

      <div class="container-base relative z-10">
        <div class="flex flex-col items-center text-center gap-8 max-w-4xl mx-auto">
          <div class="space-y-4">
            <span class="text-primary font-bold tracking-widest uppercase text-sm" data-i18n="home.vote.tag">Evento Especial</span>
            <h2 class="text-4xl md:text-5xl lg:text-7xl font-black text-foreground italic tracking-tighter uppercase leading-[0.9]" data-i18n="home.vote.title">
              VOTA POR TU RAZA FAVORITA
            </h2>
          </div>
          
          <p class="text-xl md:text-2xl text-foreground/80 leading-relaxed font-medium" data-i18n="home.vote.description">
            El destino de la próxima actualización está en tus manos. Participa en la votación global y decide qué nueva raza se unirá primero a DragonMineZ.
          </p>
          
          <div class="pt-6">
            <a href="/vote">
              <Button variant="primary" size="lg" className="gap-3 shadow-hero hover:shadow-glow-strong">
                <span class="material-symbols-rounded text-2xl">how_to_vote</span>
                <span data-i18n="home.vote.cta" class="text-lg">Ir a Votar Ahora</span>
              </Button>
            </a>
          </div>
        </div>
      </div>
    </section>

    <div class="section-divider"></div>

    <!-- ── Hero Salon -->
    <section class="py-24 md:py-32 overflow-hidden bg-section">

      <div class="container-base grid grid-cols-1 md:grid-cols-2 items-center gap-12">
        
        <div class="relative flex justify-center md:justify-start">
          <Image 
            src={characters} 
            alt="DragonMineZ Characters Showcase" 
            class="w-full max-w-[520px] md:max-w-none md:w-[110%] md:-ml-8 h-auto object-contain drop-shadow-portrait transition-all duration-700 ease-out hover:scale-105"
          />
        </div>

        <div class="flex flex-col gap-8 text-left">
          <div class="space-y-4">
            <span class="text-foreground font-bold tracking-widest uppercase text-sm" data-i18n="home.salon.tag">Tu Guerrero, Tu Estilo</span>
            <h2 class="text-4xl md:text-5xl lg:text-6xl font-black text-foreground leading-[1.1] italic tracking-tighter uppercase" data-i18n="home.salon.title">
              DISEÑA TU <br/>PROPIA IDENTIDAD
            </h2>
          </div>
          <div class="flex flex-col gap-5">
            <p class="text-lg text-foreground/80 leading-relaxed" data-i18n="home.salon.description1">
              En DragonMineZ, no eres solo un jugador más. Te ofrecemos las herramientas para que tu guerrero sea verdaderamente único.
            </p>
            <p class="text-lg text-foreground/80 leading-relaxed" data-i18n="home.salon.description2">
              A través de nuestro HairSalon, puedes explorar miles de modelos creados por la comunidad o subir los tuyos propios usando nuestro visor 3D en tiempo real.
            </p>
          </div>
          <div class="pt-2 flex flex-wrap gap-4">
            <a href="/hairsalon">
              <Button variant="primary" size="lg" className="gap-3">
                <span class="material-symbols-rounded text-xl">styler</span>
                <span data-i18n="home.salon.cta">Explorar el Salón</span>
              </Button>
            </a>
          </div>
        </div>

      </div>
    </section>

    <div class="section-divider"></div>

    <!-- ── Video -->
    <section class="py-24 md:py-32 bg-section">

      <div class="container-base flex flex-col items-center gap-16">
        <div class="flex flex-col gap-4 text-center">
          <h3 class="text-3xl md:text-5xl font-black text-foreground italic tracking-tight uppercase" data-i18n="home.video.title">
            Acción en Estado Puro
          </h3>
          <p class="text-foreground/60 max-w-xl mx-auto leading-relaxed text-lg" data-i18n="home.video.description">
            Echa un vistazo a la fluidez del combate y los efectos visuales que hacen de DragonMineZ una experiencia inigualable.
          </p>
        </div>
        
        <div class="relative w-full aspect-video rounded-[3rem] overflow-hidden border border-foreground/20 shadow-hero bg-black/20 group dark:border-glass">
          <div class="absolute inset-0 transition-transform duration-700 group-hover:scale-105">
            <iframe 
              class="absolute inset-0 w-full h-full"
              src="https://www.youtube.com/embed/0IBVdM9WE9Q" 
              title="DragonMineZ - End of Z Update Trailer" 
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
              referrerpolicy="strict-origin-when-cross-origin" 
              allowfullscreen
            ></iframe>
          </div>
        </div>
      </div>
    </section>

    <div class="section-divider"></div>

    <!-- ── Gallery -->
    <section class="py-24 md:py-32 bg-section">

      <div class="container-base flex flex-col items-center gap-16">
        <div class="flex flex-col gap-4 text-center">
          <h3 class="text-3xl md:text-5xl font-black text-foreground italic tracking-tight uppercase" data-i18n="home.gallery.title">
            Galería del Mundo
          </h3>
          <p class="text-foreground/60 max-w-lg mx-auto leading-relaxed text-lg" data-i18n="home.gallery.description">
            Capturas directas desde el corazón de la aventura.
          </p>
        </div>
        <ImageCarousel />
      </div>
    </section>

    <!-- ── Community -->
    <section class="py-24 md:py-32">

      <div class="container-base">
        <div class="relative overflow-hidden rounded-[4rem] bg-[#5865F2] p-12 md:p-24 text-center flex flex-col items-center justify-center gap-10 shadow-alert">
          <div class="absolute inset-0 z-0 opacity-10 flex items-center justify-center">
            <i class="fa-brands fa-discord text-[45rem] rotate-12"></i>
          </div>
          <div class="relative z-10 space-y-8">
            <div class="space-y-4">
              <h2 class="text-4xl md:text-7xl font-black text-white italic tracking-tighter uppercase leading-[0.9]" data-i18n="home.community.title">
                ÚNETE A LA PATRULLA <br/>DEL TIEMPO
              </h2>
              <p class="text-xl md:text-2xl text-white/90 max-w-2xl mx-auto font-medium leading-relaxed" data-i18n="home.community.description">
                Conéctate con miles de jugadores, encuentra grupos para incursiones y obtén soporte directo de los desarrolladores.
              </p>
            </div>
            <div class="flex justify-center pt-4">
              <a 
                href="https://discord.com/servers/dragonmine-z-1216429657273012415" 
                target="_blank" 
                rel="noopener noreferrer"
                class="inline-flex items-center gap-4 px-12 py-6 bg-foreground text-background rounded-full font-black text-xl transition-all hover:scale-110 active:scale-95 shadow-hero hover:shadow-glow-strong"
              >
                <i class="fa-brands fa-discord text-3xl"></i>
                <span data-i18n="home.community.cta">ENTRAR AL DISCORD</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>
</Layout>