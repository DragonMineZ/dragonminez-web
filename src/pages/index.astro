---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import aurora from "../assets/updates/dmz-aurora.png";
import auroraLogo from "../assets/updates/dmz-aurora-logo.png";
import characters from "../assets/dmz-characters.png";
import ImageCarousel from "../components/ImageCarousel.astro";
import VideoHero from "../components/landing/VideoHero.astro";
import ShowcaseSection from "../components/landing/ShowcaseSection.astro";
import { Button } from "../components/ui/Button";
import { showcaseItems } from "../config/landing";
---

<Layout>
  <main>

    <!-- ─────────────────────────────────────────────────────────────────────
         HERO — cinematic video reel / Ken Burns static fallback
    ───────────────────────────────────────────────────────────────────────── -->
    <VideoHero />


    <!-- ─────────────────────────────────────────────────────────────────────
         MEDIA SHOWCASE — alternating sections per showcaseItem
    ───────────────────────────────────────────────────────────────────────── -->
    {showcaseItems.map((item, i) => (
      <ShowcaseSection item={item} flip={i % 2 === 0} index={i} />
    ))}


    <!-- ─────────────────────────────────────────────────────────────────────
         AURORA UPDATE
    ───────────────────────────────────────────────────────────────────────── -->
    <section class="relative py-24 md:py-36 bg-background overflow-hidden">
      <!-- Top separator -->
      <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-white/8 to-transparent"></div>

      <!-- Ambient glow -->
      <div class="absolute inset-0 pointer-events-none">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[300px] rounded-full opacity-[0.04] blur-[100px] bg-white"></div>
      </div>

      <div class="container-base">
        <div class="flex flex-col lg:flex-row items-center gap-12 md:gap-20">

          <!-- Text side -->
          <div class="flex-1 flex flex-col gap-8">
            <div class="flex flex-col gap-4">
              <span
                class="reveal reveal-up inline-block text-xs font-bold tracking-[0.2em] uppercase text-white/45 border border-white/10 rounded-full px-4 py-1.5 w-fit"
                data-i18n="home.aurora.tag"
              >Última Versión</span>

              <div class="reveal reveal-up reveal-delay-1">
                <span class="sr-only" data-i18n="home.aurora.title">AURORA UPDATE</span>
                <Image
                  src={auroraLogo}
                  alt="Aurora Update Logo"
                  class="h-20 md:h-28 w-auto object-contain drop-shadow-[0_0_40px_rgba(255,100,0,0.25)] transition-transform duration-500 hover:scale-[1.03]"
                />
              </div>
            </div>

            <p
              class="reveal reveal-up reveal-delay-2 text-lg text-white/60 leading-relaxed max-w-xl"
              data-i18n="home.aurora.description"
            >
              Nuestra mayor actualización hasta la fecha. Hemos rediseñado por completo el sistema de renderizado para ofrecer efectos visuales impresionantes, nuevas transformaciones y una estabilidad sin precedentes.
            </p>

            <div class="reveal reveal-up reveal-delay-3">
              <a href="#">
                <Button variant="primary" size="lg" className="gap-3">
                  <span class="material-symbols-rounded text-xl">article</span>
                  <span data-i18n="home.aurora.cta">Ver Notas del Parche</span>
                </Button>
              </a>
            </div>
          </div>

          <!-- Image side -->
          <div class="reveal reveal-right flex-1 w-full">
            <div class="relative group cursor-pointer overflow-hidden rounded-3xl border border-white/8 gradient-border shadow-[0_0_60px_rgba(0,0,0,0.5)] transition-all duration-500 hover:border-white/15 hover:shadow-[0_0_80px_rgba(0,0,0,0.65)]">
              <Image
                src={aurora}
                alt="Aurora Update Preview"
                class="w-full h-auto object-cover transition-transform duration-700 group-hover:scale-[1.03]"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-70 group-hover:opacity-40 transition-opacity duration-500"></div>
            </div>
          </div>

        </div>
      </div>
    </section>


    <!-- ─────────────────────────────────────────────────────────────────────
         HAIR SALON PROMO
    ───────────────────────────────────────────────────────────────────────── -->
    <section class="relative py-24 md:py-36 overflow-hidden bg-[#0d0d0f]">
      <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-white/8 to-transparent"></div>

      <!-- Ambient -->
      <div class="absolute inset-0 pointer-events-none">
        <div class="absolute bottom-0 right-0 w-[500px] h-[400px] rounded-full opacity-[0.03] blur-[120px] bg-white"></div>
      </div>

      <div class="container-base grid grid-cols-1 lg:grid-cols-2 items-center gap-12 md:gap-16">

        <!-- Character art (left on desktop) -->
        <div class="reveal reveal-left relative flex justify-center lg:justify-start order-2 lg:order-1">
          <Image
            src={characters}
            alt="DragonMineZ Characters"
            class="w-full max-w-[440px] lg:max-w-none lg:w-[115%] lg:-ml-10 h-auto object-contain drop-shadow-[0_0_80px_rgba(0,0,0,0.7)] transition-all duration-700 ease-out hover:scale-[1.03]"
            loading="lazy"
          />
        </div>

        <!-- Text (right on desktop) -->
        <div class="flex flex-col gap-7 text-left order-1 lg:order-2">
          <span
            class="reveal reveal-up inline-block text-xs font-bold tracking-[0.2em] uppercase text-white/45 border border-white/10 rounded-full px-4 py-1.5 w-fit"
            data-i18n="home.salon.tag"
          >Tu Guerrero, Tu Estilo</span>

          <h2
            class="reveal reveal-up reveal-delay-1 text-4xl md:text-5xl lg:text-[3.5rem] font-black text-white italic leading-[0.95] tracking-tighter uppercase"
            data-i18n="home.salon.title"
          >
            DISEÑA TU<br/>PROPIA IDENTIDAD
          </h2>

          <div class="flex flex-col gap-4">
            <p
              class="reveal reveal-up reveal-delay-2 text-lg text-white/60 leading-relaxed"
              data-i18n="home.salon.description1"
            >
              En DragonMineZ, no eres solo un jugador más. Te ofrecemos las herramientas para que tu guerrero sea verdaderamente único.
            </p>
            <p
              class="reveal reveal-up reveal-delay-3 text-lg text-white/60 leading-relaxed"
              data-i18n="home.salon.description2"
            >
              A través de nuestro HairSalon, puedes explorar miles de modelos creados por la comunidad o subir los tuyos propios usando nuestro visor 3D en tiempo real.
            </p>
          </div>

          <div class="reveal reveal-up reveal-delay-4 pt-1">
            <a href="/hairsalon">
              <Button variant="primary" size="lg" className="gap-3">
                <span class="material-symbols-rounded text-xl">styler</span>
                <span data-i18n="home.salon.cta">Explorar el Salón</span>
              </Button>
            </a>
          </div>
        </div>

      </div>
    </section>


    <!-- ─────────────────────────────────────────────────────────────────────
         YOUTUBE VIDEO
    ───────────────────────────────────────────────────────────────────────── -->
    <section class="relative py-24 md:py-36 bg-background overflow-hidden">
      <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-white/8 to-transparent"></div>

      <div class="container-base flex flex-col items-center gap-12">

        <!-- Heading -->
        <div class="flex flex-col gap-4 text-center max-w-2xl mx-auto">
          <h3
            class="reveal reveal-up text-3xl md:text-5xl font-black text-white italic tracking-tight uppercase"
            data-i18n="home.video.title"
          >
            Acción en Estado Puro
          </h3>
          <p
            class="reveal reveal-up reveal-delay-1 text-white/50 leading-relaxed text-lg"
            data-i18n="home.video.description"
          >
            Echa un vistazo a la fluidez del combate y los efectos visuales que hacen de DragonMineZ una experiencia inigualable.
          </p>
        </div>

        <!-- Video embed -->
        <div class="reveal reveal-scale reveal-delay-1 relative w-full aspect-video rounded-3xl overflow-hidden border border-white/8 gradient-border shadow-[0_0_80px_rgba(0,0,0,0.6)] bg-black group">
          <div class="absolute inset-0 transition-transform duration-700 group-hover:scale-[1.01]">
            <iframe
              class="absolute inset-0 w-full h-full"
              src="https://www.youtube.com/embed/Y7HnXFOK0w4"
              title="DragonMineZ - Aurora Update Trailer"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              referrerpolicy="strict-origin-when-cross-origin"
              allowfullscreen
            ></iframe>
          </div>
        </div>

      </div>
    </section>


    <!-- ─────────────────────────────────────────────────────────────────────
         GALLERY
    ───────────────────────────────────────────────────────────────────────── -->
    <section class="relative py-24 md:py-36 bg-[#0d0d0f] overflow-hidden">
      <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-white/8 to-transparent"></div>

      <div class="container-base flex flex-col items-center gap-12">

        <!-- Heading -->
        <div class="flex flex-col gap-4 text-center max-w-2xl mx-auto">
          <h3
            class="reveal reveal-up text-3xl md:text-5xl font-black text-white italic tracking-tight uppercase"
            data-i18n="home.gallery.title"
          >
            Galería del Mundo
          </h3>
          <p
            class="reveal reveal-up reveal-delay-1 text-white/50 leading-relaxed text-lg"
            data-i18n="home.gallery.description"
          >
            Capturas directas desde el corazón de la aventura.
          </p>
        </div>

        <!-- Gallery carousel -->
        <div class="reveal reveal-scale reveal-delay-2 w-full">
          <ImageCarousel />
        </div>

      </div>
    </section>


    <!-- ─────────────────────────────────────────────────────────────────────
         COMMUNITY / DISCORD CTA
    ───────────────────────────────────────────────────────────────────────── -->
    <section class="py-24 md:py-36 bg-background">
      <div class="container-base">

        <div class="reveal reveal-scale relative overflow-hidden rounded-[3rem] md:rounded-[4rem] bg-[#5865F2] p-10 md:p-20 text-center flex flex-col items-center justify-center gap-10 shadow-[0_0_120px_rgba(88,101,242,0.3)]">

          <!-- Background icon -->
          <div class="absolute inset-0 z-0 opacity-[0.07] flex items-center justify-center overflow-hidden pointer-events-none select-none">
            <i class="fa-brands fa-discord text-[40rem] rotate-12"></i>
          </div>

          <!-- Gradient ring highlight -->
          <div class="absolute inset-0 rounded-[inherit] pointer-events-none"
               style="background: linear-gradient(135deg, rgba(255,255,255,0.08) 0%, transparent 60%);"></div>

          <div class="relative z-10 flex flex-col items-center gap-8">
            <div class="flex flex-col items-center gap-3">
              <h2
                class="text-4xl md:text-6xl lg:text-7xl font-black text-white italic tracking-tighter uppercase leading-[0.9]"
                data-i18n="home.community.title"
              >
                ÚNETE A LA PATRULLA<br/>DEL TIEMPO
              </h2>
              <p
                class="text-lg md:text-xl text-white/85 max-w-2xl font-medium leading-relaxed"
                data-i18n="home.community.description"
              >
                Conéctate con miles de jugadores, encuentra grupos para incursiones y obtén soporte directo de los desarrolladores.
              </p>
            </div>

            <a
              href="https://discord.com/servers/dragonmine-z-1216429657273012415"
              target="_blank"
              rel="noopener noreferrer"
              class="btn-shine inline-flex items-center gap-4 px-10 py-5 bg-white text-[#5865F2] rounded-full font-black text-lg uppercase tracking-wide transition-all duration-300 hover:scale-105 hover:shadow-[0_0_60px_rgba(255,255,255,0.3)] active:scale-95"
            >
              <i class="fa-brands fa-discord text-2xl"></i>
              <span data-i18n="home.community.cta">ENTRAR AL DISCORD</span>
            </a>
          </div>

        </div>
      </div>
    </section>

  </main>
</Layout>
